# ==============================================================================
# Offline Auto Audit — 环境变量配置模板
# 复制此文件为 .env 并根据本地环境调整配置
# ==============================================================================

# ──────────────────────────────────────────────
# 语音识别配置 (transcribe.py)
# ──────────────────────────────────────────────

# whisper-cli 的绝对路径（如果已在 PATH 中可直接填 whisper-cli 或 whisper）
WHISPER_CLI=/Users/tenan/whisper.cpp/build/bin/whisper-cli

# whisper.cpp 动态库路径 (仅 macOS 运行时可能需要加载)
WHISPER_LIB_DIR=/Users/tenan/whisper.cpp/build/src

# 本地 Whisper 模型文件路径
WHISPER_MODEL=/Users/tenan/whisper.cpp/models/ggml-medium.bin

# 识别目标语言 (zh: 中文, en: 英文, auto: 自动识别)
WHISPER_LANGUAGE=zh

# 语音识别使用的线程数 (默认使用全部 CPU 核心)
# WHISPER_THREADS=4

# ──────────────────────────────────────────────
# 合规审计配置 (app.py)
# ──────────────────────────────────────────────

# 本地大语言模型 (Ollama)
AUDIT_MODEL=qwen3.5:9b

# 本地向量嵌入模型 (Ollama)
EMBED_MODEL=nomic-embed-text

# 向量库构建时的 Embedding 并发度
EMBEDDING_CONCURRENCY=2

# RAG 语义检索过滤阀值 (余弦距离，越小匹配度越高，通常 0.0 - 1.0)
RELEVANCE_THRESHOLD=0.5
